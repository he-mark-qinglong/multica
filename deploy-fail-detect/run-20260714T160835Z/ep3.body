\",\"no_project\":\"No project\",\"project_unavailable\":\"Project unavailable\",\"field_prompt\":\"Prompt\",\"add_trigger\":\"Add trigger\",\"no_triggers\":\"No triggers configured. Add a schedule to run automatically.\",\"no_runs\":\"No runs yet. Click \\\"Run now\\\" to trigger manually.\",\"delete_button\":\"Delete autopilot\",\"toast_deleted\":\"Autopilot deleted\",\"toast_delete_failed\":\"Failed to delete autopilot\",\"delete_dialog\":{\"title\":\"Delete autopilot\",\"description\":\"This will permanently delete \\\"{{title}}\\\", along with its triggers and run history. This action cannot be undone.\",\"cancel\":\"Cancel\",\"confirm\":\"Delete\",\"deleting\":\"Deleting...\"}},\"run_status\":{\"issue_created\":\"Issue Created\",\"running\":\"Running\",\"skipped\":\"Skipped\",\"completed\":\"Completed\",\"failed\":\"Failed\"},\"run_source\":{\"schedule\":\"Schedule\",\"manual\":\"Manual\",\"webhook\":\"Webhook\",\"api\":\"API\"},\"run\":{\"issue_linked\":\"Issue linked\",\"view_log\":\"View execution log\",\"skipped_group\":{\"label\":\"Skipped\",\"summary\":\"{{count}} skipped runs\"}},\"webhook_payload\":{\"label\":\"Webhook event:\",\"unknown_event\":\"webhook.received\",\"payload\":\"Payload\",\"content_type\":\"Content-Type: {{type}}\",\"copy\":\"Copy\",\"copied\":\"Webhook payload copied\",\"copied_short\":\"Copied\",\"copy_failed\":\"Failed to copy\",\"truncated_marker\":\"[truncated — click Copy to get the full payload]\"},\"trigger_kind\":{\"schedule\":\"Schedule\",\"webhook\":\"Webhook\",\"api\":\"API\"},\"trigger_row\":{\"disabled_badge\":\"Disabled\",\"deprecated_badge\":\"Deprecated\",\"next_label\":\"Next: {{date}}\",\"webhook_url_label\":\"Webhook URL\",\"copy_url\":\"Copy URL\",\"url_copied\":\"Webhook URL copied\",\"url_copy_failed\":\"Failed to copy\",\"rotate_url\":\"Rotate URL\",\"rotate_confirm_title\":\"Rotate webhook URL\",\"rotate_confirm_description\":\"The current URL will stop working immediately. Any external systems calling it must